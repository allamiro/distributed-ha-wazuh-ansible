# {{ ansible_managed }}
# Wazuh dashboard {{ inventory_hostname }}

server.host: "{{ dashboard_server_host }}"
server.port: {{ dashboard_port }}

opensearch.hosts:
{% for host in dashboard_opensearch_hosts %}
  - "{{ host }}"
{% endfor %}

{% if enable_ssl | default(true) %}
# Auth credentials are needed whenever the security plugin is on, regardless of
# whether the HTTP layer is TLS or plain.
opensearch.username: "{{ dashboard_opensearch_username }}"
opensearch.password: "{{ dashboard_opensearch_password }}"
{% endif %}
{% if http_tls | default(true) %}
opensearch.ssl.verificationMode: certificate
opensearch.ssl.certificateAuthorities:
  - "{{ dashboard_certs_dir }}/root-ca.pem"
server.ssl.enabled: true
server.ssl.key: "{{ dashboard_certs_dir }}/{{ inventory_hostname }}-key.pem"
server.ssl.certificate: "{{ dashboard_certs_dir }}/{{ inventory_hostname }}.pem"
{% if enable_ssl | default(true) %}
opensearch_security.cookie.secure: true
{% endif %}
{% else %}
opensearch.ssl.verificationMode: none
server.ssl.enabled: false
{% endif %}

{% if enable_ssl | default(true) %}
# Security-plugin settings — only valid when the security plugin is present
# (SSL build). In the no-SSL build the plugin is removed, so these are omitted.
opensearch.requestHeadersAllowlist: ["securitytenant", "Authorization"]
opensearch_security.multitenancy.enabled: {{ dashboard_multitenancy_enabled | default(false) | string | lower }}
opensearch_security.multitenancy.tenants.preferred: ["Global", "Private"]
opensearch_security.readonly_mode.roles: ["kibana_read_only"]
{% endif %}
uiSettings.overrides.defaultRoute: {{ dashboard_default_route }}
