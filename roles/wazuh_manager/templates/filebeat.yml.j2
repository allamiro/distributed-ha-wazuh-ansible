# {{ ansible_managed }}
# Filebeat on Wazuh server node {{ inventory_hostname }} -> indexer cluster

output.elasticsearch:
  hosts:
{% for host in filebeat_indexer_hosts %}
    - "{{ host }}"
{% endfor %}
{% if enable_ssl | default(true) %}
  protocol: https
  username: "{{ filebeat_indexer_username }}"
  password: "{{ filebeat_indexer_password }}"
  ssl.certificate_authorities:
    - "{{ filebeat_certs_dir }}/root-ca.pem"
  ssl.certificate: "{{ filebeat_certs_dir }}/{{ inventory_hostname }}.pem"
  ssl.key: "{{ filebeat_certs_dir }}/{{ inventory_hostname }}-key.pem"
{% else %}
  protocol: http
{% endif %}

setup.template.json.enabled: true
setup.template.json.path: '/etc/filebeat/wazuh-template.json'
setup.template.json.name: 'wazuh'
setup.ilm.overwrite: true
setup.ilm.enabled: false

filebeat.modules:
  - module: wazuh
    alerts:
      enabled: true
    archives:
      enabled: false

logging.level: info
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat
  keepfiles: 7
  permissions: 0644

logging.metrics.enabled: false

# Allow the rseq syscall so Filebeat starts on modern (Rocky 9) kernels
seccomp:
  default_action: allow
  syscalls:
    - action: allow
      names:
        - rseq
